{
  "name": "happie-desktop",
  "version": "1.0.0",
  "description": "HAPIE - Hardware-Aware Performance Inference Engine - Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:frontend": "cd ../frontend && pnpm build",
    "dist": "electron-builder --win --x64",
    "dist:dir": "electron-builder --win --x64 --dir"
  },
  "dependencies": {
    "electron-log": "^5.2.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.happie.desktop",
    "productName": "HAPIE",
    "copyright": "Copyright © 2024 HAPIE",
    "directories": {
      "output": "../dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../frontend/out",
        "to": "frontend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../backend/dist/hapie-backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "artifactName": "HAPIE-Desktop-Setup.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "HAPIE",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerSidebar": "assets/installer-sidebar.png",
      "installerHeader": "assets/installer-header.png",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    }
  }
}
